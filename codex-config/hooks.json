{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/ai-workbench-container/SessionStart-codex.sh",
            "timeout": 30,
            "statusMessage": "Loading Workbench context"
          }
        ]
      }
    ]
  }
}
