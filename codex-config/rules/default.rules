# Command approval policy for AI Workbench containers.

prefix_rule(
    pattern = ["git", "add"],
    decision = "prompt",
    justification = "Staging changes affects the user's repository state; ask before doing it.",
    match = ["git add README.md"],
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Creating commits should be explicit user intent.",
    match = ["git commit -m update"],
)

prefix_rule(
    pattern = ["git", "config"],
    decision = "prompt",
    justification = "Git configuration changes can persist beyond the current task.",
    match = ["git config user.email user@example.com"],
)

prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "Workbench runtime containers run as the workbench user; put system changes in apt.txt, preBuild.bash, or postBuild.bash and rebuild.",
    match = ["sudo apt-get update"],
)

prefix_rule(
    pattern = ["pip", "install"],
    decision = "forbidden",
    justification = "Do not mutate the running Workbench Python environment; edit requirements.txt or build scripts and rebuild instead.",
    match = ["pip install requests"],
)

prefix_rule(
    pattern = ["pip3", "install"],
    decision = "forbidden",
    justification = "Do not mutate the running Workbench Python environment; edit requirements.txt or build scripts and rebuild instead.",
    match = ["pip3 install requests"],
)

prefix_rule(
    pattern = ["python", "-m", "pip", "install"],
    decision = "forbidden",
    justification = "Do not mutate the running Workbench Python environment; edit requirements.txt or build scripts and rebuild instead.",
    match = ["python -m pip install requests"],
)

prefix_rule(
    pattern = ["python3", "-m", "pip", "install"],
    decision = "forbidden",
    justification = "Do not mutate the running Workbench Python environment; edit requirements.txt or build scripts and rebuild instead.",
    match = ["python3 -m pip install requests"],
)

prefix_rule(
    pattern = ["docker"],
    decision = "forbidden",
    justification = "Docker is controlled by the Workbench host, not from inside the project container.",
    match = ["docker ps"],
)

prefix_rule(
    pattern = ["podman"],
    decision = "forbidden",
    justification = "Container runtime operations are controlled outside the Workbench project container.",
    match = ["podman ps"],
)

prefix_rule(
    pattern = ["nvwb"],
    decision = "forbidden",
    justification = "The Workbench CLI is not available inside the project container; ask the user to run host-side Workbench actions.",
    match = ["nvwb validate project-spec"],
)
